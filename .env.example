# Meta Conversions API (CAPI) - tracking serveur
# Token à générer dans Events Manager > Paramètres > API de conversions > Générer un token
# SECRET : ne jamais committer la vraie valeur. À renseigner dans Vercel (Production + Preview).
META_CAPI_ACCESS_TOKEN=
# Optionnel : surcharge l'ID du pixel (défaut = celui du code, 4518512965138257)
# META_PIXEL_ID=
# Optionnel : code de test pour valider l'intégration (Events Manager > Test events)
# META_TEST_EVENT_CODE=
# Optionnel : version de l'API Graph (défaut = v21.0)
# META_GRAPH_VERSION=v21.0
